{
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light Soft",
    "dark": "Gruvbox Dark Soft",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Colored Zed Icons Theme Light",
    "dark": "Colored Zed Icons Theme Dark",
  },
  "base_keymap": "VSCode",
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "ui_font_family": "FiraCode Nerd Font Mono",
  "relative_line_numbers": "enabled",
  "title_bar": {
    "show_branch_icon": true,
  },
  "project_panel": {
    "auto_fold_dirs": false,
  },
  "git_panel": {
    "fallback_branch_name": "master",
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "drag_and_drop_selection": {
    "delay": 0,
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
    "show_close_button": "always",
    "show_diagnostics": "all",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  // "diagnostics": {
  //   "inline": {
  //     "enabled": true,
  //   },
  // },
  "terminal": {
    "line_height": "standard",
  },
  "auto_install_extensions": {
    "proto": true,
    "git-firefly": true,
    "html": true,
    "dockerfile": true,
    "docker-compose": true,
    "make": true,
    "zig": true,
    "lua": true,
    "env": true,
    "basher": true,
    "java": true,
    "kotlin": true,
    "sql": true,
    "xml": true,
    "ansible": true,
    "jinja2": true,
    "go": true,
    "colored-zed-icons-theme": true,
  },
  "file_types": {
    "Ansible": [
      "**.ansible.yml",
      "**.ansible.yaml",
      "**/defaults/*.yml",
      "**/defaults/*.yaml",
      "**/meta/*.yml",
      "**/meta/*.yaml",
      "**/tasks/*.yml",
      "**/tasks/*.yaml",
      "**/handlers/*.yml",
      "**/handlers/*.yaml",
      "**/group_vars/*.yml",
      "**/group_vars/*.yaml",
      "**/playbooks/*.yaml",
      "**/playbooks/*.yml",
      "**playbook*.yaml",
      "**playbook*.yml",
    ],
  },
  "colorize_brackets": true,
  "languages": {
    "Zig": {
      "enable_language_server": true,
      "language_servers": ["zls"],
    },
    "Go": {
      "enable_language_server": true,
      "language_servers": ["gopls"],
    },
  },
  "lsp": {
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "schemas": {
            "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/inventory.json": [
              "./inventory/*.yml",
              "./inventory/*.yaml",
              "hosts.yml",
              "hosts.yaml",
            ],
          },
        },
      },
    },
    "gopls": {},
  },
  // "disable_ai": true,
  "edit_predictions": {
    "provider": "zed",
  },
  "proxy": "http://127.0.0.1:10808",
}
